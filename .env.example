# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Mode démo/tests sans appel externe
MOCK_LLM=false

# Stockage local des métriques
DB_PATH=data/observability.db

# Coûts indicatifs à adapter selon votre modèle / pricing Groq
TOKEN_PRICE_INPUT_1M=0.59
TOKEN_PRICE_OUTPUT_1M=0.79

# Seuils dashboard / alerting
LATENCY_THRESHOLD_MS=8000
COST_THRESHOLD_USD=0.02
