GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
MOCK_LLM=false

DB_PATH=data/observability.db
TOKEN_PRICE_INPUT_1M=0.59
TOKEN_PRICE_OUTPUT_1M=0.79
LATENCY_THRESHOLD_MS=8000
COST_THRESHOLD_USD=0.02

# Rapport Gmail automatique si le dashboard contient plus de 3 alertes
ALERT_REPORT_THRESHOLD=3
ALERT_REPORT_COOLDOWN_MINUTES=60
GMAIL_ENABLED=false
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USER=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=mot_de_passe_application_gmail
GMAIL_SENDER=votre.adresse@gmail.com
GMAIL_RECIPIENTS=destinataire1@example.com,destinataire2@example.com
